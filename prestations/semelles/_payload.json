[{"data":1,"prerenderedAt":267},["ShallowReactive",2],{"navigation":3,"/prestations/semelles":30,"/prestations/semelles-surround":241},[4],{"title":5,"_path":6,"children":7,"icon":29},"Mes prestations","/prestations",[8,11,14,17,20,23,26],{"title":9,"_path":10},"Les soins de la pédicurie","/prestations/soin-pedicurie",{"title":12,"_path":13},"Pied du diabétique","/prestations/pied-du-diabetique",{"title":15,"_path":16},"Semelles","/prestations/semelles",{"title":18,"_path":19},"Podologie du sport","/prestations/podologie-du-sport",{"title":21,"_path":22},"The Benefits of Meditation","/prestations/meditation",{"title":24,"_path":25},"The 10 Most Dangerous Creatures on Earth","/prestations/animals",{"title":27,"_path":28},"I tested Nuxt UI","/prestations/nuxt-ui","i-heroicons-newspaper",{"_path":16,"_dir":31,"_draft":32,"_partial":32,"_locale":33,"title":15,"description":34,"image":35,"date":37,"badge":38,"body":40,"_type":235,"_id":236,"_source":237,"_file":238,"_stem":239,"_extension":240},"prestations",false,"","C’est la science qui étudie la prévention, le diagnostic et la prise en charge des pathologies du pied et de l’appareil locomoteur.",{"src":36},"/semelles.webp","2024-08-01T00:00:00.000Z",{"label":39},"Podologie",{"type":41,"children":42,"toc":230},"root",[43,51,56,76,81,92,97,102,112,122,170,179,184,193,202],{"type":44,"tag":45,"props":46,"children":47},"element","p",{},[48],{"type":49,"value":50},"text","Je réalise des semelles orthopédiques à la demande du médecin, je peux aussi en prescrire (mais vous ne serez pas remboursés).",{"type":44,"tag":45,"props":52,"children":53},{},[54],{"type":49,"value":55},"Lors du premier rendez-vous, je réalise un examen clinique complet :",{"type":44,"tag":57,"props":58,"children":59},"ul",{},[60,66,71],{"type":44,"tag":61,"props":62,"children":63},"li",{},[64],{"type":49,"value":65},"Interrogatoire",{"type":44,"tag":61,"props":67,"children":68},{},[69],{"type":49,"value":70},"Examen statique global sur podoscope et sur plateforme podobarométrique",{"type":44,"tag":61,"props":72,"children":73},{},[74],{"type":49,"value":75},"Examen dynamique",{"type":44,"tag":45,"props":77,"children":78},{},[79],{"type":49,"value":80},"Il existe différents types de semelles pour différents types de pathologies pour différents patients ayants des âges et des activités différentes.Peaks and Valleys - Nature's Masterpiece",{"type":44,"tag":82,"props":83,"children":85},"h2",{"id":84},"les-semelles-thermoformées",[86],{"type":44,"tag":87,"props":88,"children":89},"strong",{},[90],{"type":49,"value":91},"Les semelles thermoformées",{"type":44,"tag":45,"props":93,"children":94},{},[95],{"type":49,"value":96},"Elles sont moulées sur le pied du patient et ont une action biomécanique.",{"type":44,"tag":45,"props":98,"children":99},{},[100],{"type":49,"value":101},"Il existe énormément de matériaux qui me permettent de faire des semelles efficaces et confortables en fonction de chaque pathologie et de chaque patient.",{"type":44,"tag":45,"props":103,"children":104},{},[105,110],{"type":44,"tag":87,"props":106,"children":107},{},[108],{"type":49,"value":109},"Pour qui :",{"type":49,"value":111}," je ne fais ce type de semelles que chez l’adulte ou l’adolescent, le sportif et les personnes qui recherchent du confort, personnes âgées, diabétiques…",{"type":44,"tag":45,"props":113,"children":114},{},[115,120],{"type":44,"tag":87,"props":116,"children":117},{},[118],{"type":49,"value":119},"Pour quoi :",{"type":49,"value":121}," talalgie, aponévrosite plantaire (épine calcanéenne), douleur de l’avant pied, problèmes de genoux, tendinite de la patte d’oie, syndrome de l’essuie-glace, périsostite tibiale, instabilité de cheville, fonte du capiton plantaire, problèmes de dos, inégalité vraie des membres inférieurs…",{"type":44,"tag":123,"props":124,"children":130},"div",{"className":125},[126,127,128,129],"flex","space-x-4","items-center","justify-between",[131,146,158],{"type":44,"tag":123,"props":132,"children":133},{},[134],{"type":44,"tag":45,"props":135,"children":136},{},[137],{"type":44,"tag":138,"props":139,"children":145},"img",{"alt":140,"className":141,"height":143,"src":144,"width":143},"semelle thermophormées bleues",[142],"rounded-lg",400,"/semelle_thermo_1.jpg",[],{"type":44,"tag":123,"props":147,"children":148},{},[149],{"type":44,"tag":45,"props":150,"children":151},{},[152],{"type":44,"tag":138,"props":153,"children":157},{"alt":154,"className":155,"height":143,"src":156,"width":143},"semelle thermophormées vertes",[142],"/semelle_thermo_2.jpg",[],{"type":44,"tag":123,"props":159,"children":160},{},[161],{"type":44,"tag":45,"props":162,"children":163},{},[164],{"type":44,"tag":138,"props":165,"children":169},{"alt":166,"className":167,"height":143,"src":168,"width":143},"semelle thermophormées rouges",[142],"/semelle_thermo_3.jpg",[],{"type":44,"tag":82,"props":171,"children":173},{"id":172},"les-semelles-proprioceptives",[174],{"type":44,"tag":87,"props":175,"children":176},{},[177],{"type":49,"value":178},"Les semelles proprioceptives",{"type":44,"tag":45,"props":180,"children":181},{},[182],{"type":49,"value":183},"Ce sont des semelles fines, les calles ne font pas plus de 4 mm, elles agissent sur les récepteurs des muscles et des tendons qu’elles vont stimuler ou inhiber et ainsi agir comme une rééducation.",{"type":44,"tag":45,"props":185,"children":186},{},[187,191],{"type":44,"tag":87,"props":188,"children":189},{},[190],{"type":49,"value":109},{"type":49,"value":192}," les enfants et les adultes.",{"type":44,"tag":45,"props":194,"children":195},{},[196,200],{"type":44,"tag":87,"props":197,"children":198},{},[199],{"type":49,"value":119},{"type":49,"value":201}," les pieds plats, les pieds creux, en dehors ou en dedans, mais elles agissent aussi plus haut pour aider à corriger un trouble postural et ainsi soulager des maux de genoux, de bassin, de dos…",{"type":44,"tag":123,"props":203,"children":205},{"className":204},[126,127,128,129],[206,218],{"typ